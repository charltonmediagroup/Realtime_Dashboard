# --- Local datastore (SQLite) ---
# Directory where the SQLite file (app.db) is stored.
# Defaults to ./data relative to the app if unset.
# On a Linux production host, point this at a persistent, writable path.
# DATA_DIR=/var/lib/ga4-dashboard

# Force a specific backend. Omit for automatic behavior:
#   - default: try SQLite first; fall back to MongoDB if SQLite init fails
#   - sqlite:  always use SQLite (no fallback)
#   - mongodb: always use MongoDB
# DB_BACKEND=sqlite

# --- MongoDB (optional fallback) ---
# Only required if you want the automatic Mongo fallback to work, or if
# DB_BACKEND=mongodb. Leave unset on a pure-local Linux deploy.
# MONGODB_URI=
# MONGODB_DB=

# --- Vimeo / Drupal / GA4 / etc. ---
# Copy the rest of your real values from .env.local.
